{
  "name": "relevant-xkcd",
  "version": "0.1.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "corpus:fetch": "node scripts/fetch-corpus.ts",
    "corpus:status": "node scripts/corpus-status.ts",
    "generate:manifest": "node scripts/build-index-manifest.ts",
    "generate:semantic": "node scripts/build-semantic-index.ts && node scripts/build-index-manifest.ts",
    "update:index": "node scripts/update-public-index.ts",
    "validate:index": "node scripts/validate-public-index.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "verify": "npm run validate:index && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@taylorvance/tv-shared-web": "^0.8.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@taylorvance/tv-shared-dev": "^0.1.1",
    "@types/node": "^25.0.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.0.15"
  }
}
